# Server
PORT=3000
NODE_ENV=production

# Database
DATABASE_PATH=/app/data/competitor-monitor.db

# Email
RESEND_API_KEY=re_xxx

# Public URL
PUBLIC_URL=https://your-domain.com

# Proton VPN (OpenVPN) - Paste your config here
# Get from: account.protonvpn.com > Downloads > OpenVPN config
# Copy the ENTIRE .ovpn file content below (base64 encoded or raw)

# Option 1: Raw OpenVPN config (paste entire .ovpn content)
OPENVPN_CONFIG="
client
dev tun
proto udp
remote us-free-01.protonvpn.com 1194
resolv-retry infinite
nobind
cipher AES-256-GCM
auth SHA512
verb 3
<ca>
-----BEGIN CERTIFICATE-----
[PASTE CA CERT HERE]
-----END CERTIFICATE-----
</ca>
<tls-crypt>
[PASTE TLS KEY HERE]
</tls-crypt>
"

# Option 2: Base64 encoded (easier for multi-line)
# cat protonvpn.ovpn | base64 -w 0
OPENVPN_CONFIG_BASE64=LS0tLS1CRUdJTiB...

# Proton VPN OpenVPN Credentials
# Get from: account.protonvpn.com > Settings > OpenVPN / IKEv2 credentials
# (Different from your account login!)
OPENVPN_USERNAME=your_openvpn_username
OPENVPN_PASSWORD=your_openvpn_password
