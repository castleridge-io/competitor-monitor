# Environment Variables

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_PATH=./data/competitor-monitor.db

# Resend (Email)
RESEND_API_KEY=re_xxx

# Public URL (for shareable reports)
PUBLIC_URL=http://localhost:3000

# Proxy for scraping (RECOMMENDED)
# Prevents IP blocks when scraping competitors
PROXY_SERVER=http://your-vpn-server:port
PROXY_USER=
PROXY_PASS=
